<Window x:Class="GameLauncher.Views.AddGameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加游戏"
        Width="420" Height="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- 输入框样式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderBrush="#3A3A3E"
                                BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            Background="#1A1A1E"
            BorderBrush="#2A2A2E"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="40" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    CornerRadius="20,20,0,0"
                    Background="#222226"
                    BorderBrush="#2A2A2E"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <TextBlock x:Name="DialogTitle" Text="添加游戏"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Background="Transparent"
                            Foreground="#808080"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#FF3B30"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="20,16">
                <StackPanel>
                    <!-- 拖拽区域 -->
                    <Border x:Name="DropZone"
                            CornerRadius="12"
                            Background="#1E1E22"
                            BorderBrush="#3A3A3E"
                            BorderThickness="1.5"
                            Padding="20"
                            Margin="0,0,0,16"
                            Cursor="Hand"
                            MouseLeftButtonUp="DropZone_Click">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.1" Color="Black"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="DropZoneIcon" Text="📎" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="DropZoneText" Text="拖入 exe 或快捷方式到此处" FontSize="13" Foreground="#606060" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DropZoneHint" Text="或点击浏览" FontSize="11" Foreground="#404040" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 游戏路径（拖入后显示） -->
                    <TextBlock Text="游戏路径"
                               FontSize="13"
                               Foreground="#808080"
                               Margin="4,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <TextBox x:Name="ExePathBox"
                                 Style="{StaticResource DarkTextBox}"
                                 Text=""
                                 TextChanged="ExePathBox_TextChanged"/>
                        <Button Content="浏览"
                                HorizontalAlignment="Right"
                                Margin="0,0,4,0"
                                Padding="12,8"
                                Background="Transparent"
                                Foreground="#007AFF"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BrowseExe_Click"/>
                    </Grid>

                    <!-- 游戏名称 -->
                    <TextBlock Text="显示名称（留空自动识别）"
                               FontSize="13"
                               Foreground="#808080"
                               Margin="4,0,0,8"/>
                    <TextBox x:Name="NameBox"
                             Style="{StaticResource DarkTextBox}"
                             Text=""
                             Margin="0,0,0,16"/>

                    <!-- 按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="取消"
                                Width="70"
                                Height="36"
                                Background="#28282E"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="Cancel_Click"
                                Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="#28282E" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#38383E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="ConfirmBtn"
                                Content="确定"
                                Width="70"
                                Height="36"
                                Background="#007AFF"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                IsEnabled="False"
                                Click="Confirm_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="#007AFF" CornerRadius="8">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.3" Color="#007AFF"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="b" Property="Background" Value="#3A3A3E"/>
                                            <Setter TargetName="b" Property="Effect" Value="{x:Null}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
