<Window x:Class="GameLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher.Views"
        mc:Ignorable="d"
        Title="PaoGameLun"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="Manual"
        Background="#01000000"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#007AFF"/>
        <local:HintVisibilityConverter x:Key="HintVisibilityConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
            <Grid.ColumnDefinitions>
                <!-- 左侧导航栏 -->
                <ColumnDefinition Width="92"/>
                <!-- 主内容区 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============== 左侧导航栏（玻璃效果）============== -->
            <Border x:Name="SidebarGlass" Grid.Column="0"
                    Margin="4">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#25000000" Offset="0"/>
                        <GradientStop Color="#10000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部logo/标题 -->
                    <Border Grid.Row="0" Padding="0,10">
                        <StackPanel>
                            <Image Source="pack://application:,,,/Assets/app.png"
                                   Width="36" Height="36"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center">
                                <Image.Clip>
                                    <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,36,36"/>
                                </Image.Clip>
                            </Image>
                            <!-- 搜索框 -->
                            <TextBox x:Name="SearchBox"
                                     Margin="4,8,4,0"
                                     Width="56"
                                     Height="24"
                                     FontSize="11"
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Background="#20FFFFFF"
                                     Foreground="White"
                                     CaretBrush="White"
                                     BorderThickness="0"
                                     Text="{Binding FilterText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <Grid>
                                                            <TextBlock x:Name="Hint"
                                                                       Text="搜索"
                                                                       FontSize="11"
                                                                       Foreground="#60FFFFFF"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource HintVisibilityConverter}}"/>
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <!-- 游戏图标列表 -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10,4">
                        <ItemsControl x:Name="GameIconList"
                                      ItemsSource="{Binding FilteredGames, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button ToolTip="{Binding Name}"
                                            Margin="6,4"
                                            Width="52" Height="52"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            Click="GameIcon_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="b"
                                                        Background="#15FFFFFF"
                                                        CornerRadius="12"
                                                        Cursor="Hand">
                                                    <Grid>
                                                        <Image Source="{Binding IconPath}"
                                                               Stretch="UniformToFill"
                                                               Margin="4">
                                                            <Image.Clip>
                                                                <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,44,44"/>
                                                            </Image.Clip>
                                                        </Image>
                                                        <!-- 收藏标记 -->
                                                        <Border Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Background="#007AFF"
                                                                CornerRadius="8"
                                                                Padding="4,2"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,2,2,0">
                                                            <TextBlock Text="★" Foreground="White" FontSize="10"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="b" Property="Background" Value="#30FFFFFF"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter TargetName="b" Property="Background" Value="#40FF4444"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 底部功能按钮 -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <!-- 添加游戏 -->
                        <Button ToolTip="添加游戏"
                                Margin="12,6"
                                Cursor="Hand"
                                Click="AddGame_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b"
                                            Width="48" Height="48"
                                            CornerRadius="14"
                                            Background="#20FFFFFF">
                                        <TextBlock Text="＋"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="#80FFFFFF"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentColor}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 设置 -->
                        <Button ToolTip="设置"
                                Margin="12,6"
                                Cursor="Hand"
                                Click="Settings_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b"
                                            Width="48" Height="48"
                                            CornerRadius="14"
                                            Background="Transparent">
                                        <TextBlock Text="⚙"
                                                   FontSize="20"
                                                   Foreground="#60FFFFFF"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#20FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============== 主内容区 ============== -->
            <Grid Grid.Column="1">

                <!-- 图片背景层 -->
                <Image x:Name="ImageBg"
                       Stretch="UniformToFill"
                       Visibility="Collapsed"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- 视频背景层 -->
                <MediaElement x:Name="VideoBg"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Stretch="UniformToFill"
                              Volume="1"
                              MediaEnded="VideoBg_MediaEnded"
                              Visibility="Collapsed"
                              RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- 渐变暗化遮罩 -->
                <Border x:Name="VideoOverlay" Visibility="Collapsed">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#50000000" Offset="0"/>
                            <GradientStop Color="#20000000" Offset="0.3"/>
                            <GradientStop Color="#60000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- 顶部标题栏（可拖动） -->
                <Grid Height="64" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="32,0,0,0">
                        <TextBlock x:Name="TitleText" Text="PaoGameLun" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <Border x:Name="GameNameBadge"
                                Visibility="Collapsed"
                                Background="#20FFFFFF"
                                CornerRadius="8"
                                Padding="10,4"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="GameNameIcon" Width="20" Height="20" Stretch="UniformToFill" Margin="0,0,8,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="GameNameText" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GameLastPlayedText" FontSize="12" Foreground="#808080" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 窗口控制按钮（macOS 红绿灯样式） -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,28,0" Background="Transparent">
                        <!-- 关闭 -->
                        <Button Width="14" Height="14" Margin="0,0,8,0" Click="CloseBtn_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="circle" Width="14" Height="14">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="#FF5F56"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock x:Name="icon" Text="×" FontSize="10" FontWeight="Bold" Foreground="#80000000" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#FF3B30"/>
                                            <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 最小化 -->
                        <Button Width="14" Height="14" Margin="0,0,8,0" Click="MinimizeBtn_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="circle" Width="14" Height="14">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="#FFBD2E"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock x:Name="icon" Text="−" FontSize="10" FontWeight="Bold" Foreground="#80000000" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#E6A000"/>
                                            <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 最大化 -->
                        <Button Width="14" Height="14" Click="MaximizeBtn_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="circle" Width="14" Height="14">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="#27CA3F"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock x:Name="icon" Text="□" FontSize="8" FontWeight="Bold" Foreground="#80000000" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#1FAE2D"/>
                                            <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 右下角毛玻璃启动按钮面板 -->
                <Border x:Name="LaunchButtonPanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        MinWidth="200"
                        CornerRadius="14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60000000" Offset="0"/>
                            <GradientStop Color="#40FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.3" Color="Black"/>
                    </Border.Effect>
                    <Grid Margin="10,8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 游戏图标（带圆角） -->
                            <Border Grid.Column="0" Width="36" Height="36" Margin="0,0,8,0" CornerRadius="8">
                                <Image x:Name="LaunchGameIcon" Stretch="UniformToFill">
                                    <Image.Clip>
                                        <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,36,36"/>
                                    </Image.Clip>
                                </Image>
                            </Border>

                            <!-- 开始游戏/终止运行按钮 -->
                            <Button x:Name="LaunchBtn" Grid.Column="1"
                                    Width="90"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Click="Launch_Click"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="#40FFFFFF" CornerRadius="8">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock x:Name="icon" Text="▶" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock x:Name="text" Text="开始游戏" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#60FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 收藏按钮 -->
                            <Button x:Name="FavBtn" Grid.Column="3"
                                    Width="36" Height="36"
                                    Margin="0,0,5,0"
                                    Click="ToggleFavorite_Click"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="#20FFFFFF" CornerRadius="8">
                                            <TextBlock x:Name="star" Text="☆" FontSize="14" Foreground="#80FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 设置背景按钮 -->
                            <Button x:Name="SetVideoBtn" Grid.Column="4"
                                    Width="36" Height="36"
                                    Margin="0,0,5,0"
                                    Click="SetVideo_Click"
                                    ToolTip="设置背景"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="#20FFFFFF" CornerRadius="8">
                                            <TextBlock Text="🎬" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 删除按钮 -->
                            <Button Grid.Column="5"
                                    Width="36" Height="36"
                                    Click="DeleteGame_Click"
                                    ToolTip="删除游戏"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="#20FFFFFF" CornerRadius="8">
                                            <TextBlock Text="🗑" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#40FF4444"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                    </Grid>
                </Border>

                <!-- 音量控制面板（在启动按钮上方，宽度对齐，显示游戏名称） -->
                <Border x:Name="VolumeControl"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,90"
                        MinWidth="280"
                        CornerRadius="10"
                        Padding="10,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60000000" Offset="0"/>
                            <GradientStop Color="#40FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- 游戏名称 -->
                        <TextBlock x:Name="VolumePanelGameName"
                                   Grid.Row="0"
                                   Text=""
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,6"/>
                        <!-- 控制行 -->
                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- 暂停按钮 -->
                            <Button x:Name="PauseBtn"
                                    Grid.Column="0"
                                    Width="28" Height="28"
                                    Click="Pause_Click"
                                    Cursor="Hand"
                                    VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="Transparent" CornerRadius="6">
                                            <TextBlock x:Name="PauseIcon" Text="⏸" FontSize="13" Foreground="#80FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#20FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock x:Name="VolumeIcon" Grid.Column="1" Text="🔊" FontSize="14" VerticalAlignment="Center" Foreground="#80FFFFFF" Margin="8,0,4,0"/>
                            <Slider x:Name="VolumeSlider"
                                    Grid.Column="2"
                                    Minimum="0" Maximum="100" Value="100"
                                    VerticalAlignment="Center"
                                    ValueChanged="VolumeSlider_ValueChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 模糊度控制面板（开启液态玻璃后显示，放在音量面板下方） -->
                <Border x:Name="BlurControl"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,170"
                        MinWidth="280"
                        CornerRadius="10"
                        Padding="10,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60000000" Offset="0"/>
                            <GradientStop Color="#40FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                    </Border.Effect>
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="✨" FontSize="14" VerticalAlignment="Center" Foreground="#80FFFFFF" Margin="0,0,6,0"/>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="BlurSlider"
                                    Grid.Column="0"
                                    Minimum="0" Maximum="100" Value="50"
                                    VerticalAlignment="Center"
                                    ValueChanged="BlurSlider_ValueChanged"/>
                            <TextBlock x:Name="BlurValueText" Grid.Column="1" Text="50%" FontSize="12" Foreground="#80FFFFFF" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="32"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 空状态提示 -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="还没有游戏"
                               FontSize="20"
                               Foreground="#60FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                    <TextBlock Text="点击左上角的 + 添加你的第一个游戏"
                               FontSize="14"
                               Foreground="#40FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 进程运行中提示 -->
                <Border x:Name="RunningHint"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,80,0,0"
                        Background="#CCFF4444"
                        CornerRadius="12"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️  游戏正在运行" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="终止运行"
                                Margin="12,0,0,0"
                                Padding="12,4"
                                Background="#FF3B30"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="KillProcess_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#CC2D1E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
</Window>
