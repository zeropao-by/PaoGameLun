<Window x:Class="GameLauncher.Views.SettingsPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="380" Height="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
    </Window.Resources>

    <Border CornerRadius="20"
            Background="#1A1A1E"
            BorderBrush="#2A2A2E"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="40" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    CornerRadius="20,20,0,0"
                    Background="#222226"
                    BorderBrush="#2A2A2E"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <TextBlock Text="⚙  设置"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Background="Transparent"
                            Foreground="#808080"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#FF3B30"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- 设置内容 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="20,16">
                <StackPanel>
                    <!-- 液态玻璃效果 -->
                    <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,12">
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="✨  液态玻璃效果"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="开启后窗口将呈现毛玻璃质感"
                                           FontSize="12"
                                           Foreground="#808080"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="GlassToggle"
                                          Grid.Column="1"
                                          Width="52" Height="30"
                                          Cursor="Hand"
                                          Checked="GlassToggle_Changed"
                                          Unchecked="GlassToggle_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="track"
                                                Background="#3A3A3E"
                                                CornerRadius="15"
                                                Width="52" Height="30">
                                            <Ellipse x:Name="thumb"
                                                     Width="24" Height="24"
                                                     Fill="White"
                                                     HorizontalAlignment="Left"
                                                     Margin="3,0,0,0">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.3" Color="Black"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="track" Property="Background" Value="#007AFF"/>
                                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>
                    </Border>

                    <!-- 最小化到托盘 -->
                    <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,12">
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📥  最小化到托盘"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="最小化时隐藏到系统托盘"
                                           FontSize="12"
                                           Foreground="#808080"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="TrayToggle"
                                          Grid.Column="1"
                                          Width="52" Height="30"
                                          Cursor="Hand"
                                          Checked="TrayToggle_Changed"
                                          Unchecked="TrayToggle_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="track"
                                                Background="#3A3A3E"
                                                CornerRadius="15"
                                                Width="52" Height="30">
                                            <Ellipse x:Name="thumb"
                                                     Width="24" Height="24"
                                                     Fill="White"
                                                     HorizontalAlignment="Left"
                                                     Margin="3,0,0,0">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.3" Color="Black"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="track" Property="Background" Value="#007AFF"/>
                                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>
                    </Border>

                    <!-- 开机自启动 -->
                    <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,12">
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🚀  开机自启动"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="Windows 启动时自动运行"
                                           FontSize="12"
                                           Foreground="#808080"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="AutoStartToggle"
                                          Grid.Column="1"
                                          Width="52" Height="30"
                                          Cursor="Hand"
                                          Checked="AutoStartToggle_Changed"
                                          Unchecked="AutoStartToggle_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="track"
                                                Background="#3A3A3E"
                                                CornerRadius="15"
                                                Width="52" Height="30">
                                            <Ellipse x:Name="thumb"
                                                     Width="24" Height="24"
                                                     Fill="White"
                                                     HorizontalAlignment="Left"
                                                     Margin="3,0,0,0">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.3" Color="Black"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="track" Property="Background" Value="#007AFF"/>
                                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>
                    </Border>

                    <!-- 当前游戏设置（动态显示） -->
                    <StackPanel x:Name="GameSettingsPanel" Visibility="Collapsed">
                        <TextBlock Text="当前游戏"
                                   FontSize="13"
                                   Foreground="#808080"
                                   Margin="4,8,0,10"/>

                        <!-- 收藏游戏 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="⭐  收藏游戏"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock x:Name="FavoriteStatus"
                                               Text="未收藏"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="FavoriteToggle"
                                              Grid.Column="1"
                                              Width="52" Height="30"
                                              Cursor="Hand"
                                              Checked="FavoriteToggle_Changed"
                                              Unchecked="FavoriteToggle_Changed">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="track"
                                                    Background="#3A3A3E"
                                                    CornerRadius="15"
                                                    Width="52" Height="30">
                                                <Ellipse x:Name="thumb"
                                                         Width="24" Height="24"
                                                         Fill="White"
                                                         HorizontalAlignment="Left"
                                                         Margin="3,0,0,0">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.3" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="track" Property="Background" Value="#FF9500"/>
                                                    <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                        </Border>


                        <!-- 编辑游戏 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="EditName_Click">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="✏  编辑游戏"
                                               FontSize="15"
                                               Foreground="White"/>
                                    <TextBlock Text="点击编辑游戏名称和进程名"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Text="›"
                                           Grid.Column="1"
                                           FontSize="20"
                                           Foreground="#505050"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 选择背景图片 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="SelectImage_Click">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🖼  选择背景图片"
                                               FontSize="15"
                                               Foreground="White"/>
                                    <TextBlock Text="为当前游戏设置图片背景"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Text="›"
                                           Grid.Column="1"
                                           FontSize="20"
                                           Foreground="#505050"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 选择背景视频 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="SelectVideo_Click">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🎬  选择背景视频"
                                               FontSize="15"
                                               Foreground="White"/>
                                    <TextBlock Text="视频优先级高于图片"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Text="›"
                                           Grid.Column="1"
                                           FontSize="20"
                                           Foreground="#505050"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 在线URL图片 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="SetOnlineImage_Click">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🌐  在线URL图片"
                                               FontSize="15"
                                               Foreground="White"/>
                                    <TextBlock Text="输入网络图片链接作为背景"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Text="›"
                                           Grid.Column="1"
                                           FontSize="20"
                                           Foreground="#505050"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 在线URL视频 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="SetOnlineVideo_Click">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="📹  在线URL视频"
                                               FontSize="15"
                                               Foreground="White"/>
                                    <TextBlock Text="输入网络视频链接作为背景"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Text="›"
                                           Grid.Column="1"
                                           FontSize="20"
                                           Foreground="#505050"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 清除背景 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="ClearBackground_Click">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🗑  清除背景"
                                               FontSize="15"
                                               Foreground="#FF9500"/>
                                    <TextBlock Text="移除当前游戏的背景图片和视频"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 删除游戏 -->
                        <Border CornerRadius="14" Background="#28282E" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="DeleteGame_Click">
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🗑  删除游戏"
                                               FontSize="15"
                                               Foreground="#FF3B30"/>
                                    <TextBlock Text="从启动器中移除此游戏"
                                               FontSize="12"
                                               Foreground="#808080"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 关于 -->
                    <TextBlock Text="关于"
                               FontSize="13"
                               Foreground="#808080"
                               Margin="4,16,0,10"/>

                    <Border CornerRadius="14" Background="#28282E">
                        <StackPanel Margin="16,14">
                            <TextBlock Text="PaoGameLun"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="版本 1.0.0"
                                       FontSize="12"
                                       Foreground="#808080"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="iOS 26 风格游戏聚合启动器"
                                       FontSize="12"
                                       Foreground="#606060"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
